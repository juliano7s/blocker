{
  "permissions": {
    "allow": [
      "Read(//c/Program Files/Godot/GodotSharp/Api//**)",
      "Read(//c/Program Files/Godot/GodotSharp/Tools//**)",
      "Bash(unzip -l \"/c/Program Files/Godot/GodotSharp/Tools/nupkgs/Godot.NET.Sdk.4.6.1.nupkg\")",
      "Bash(unzip:*)",
      "Bash(dotnet new:*)",
